# World Cup AI Pundit - Environment Variables
# Copy this to .env and fill in your values

# === WALRUS MEMORY (Required for live mode) ===
# Get these from https://memory.walrus.xyz
MEMWAL_DELEGATE_KEY=your-ed25519-private-key-here
MEMWAL_ACCOUNT_ID=your-memwal-account-id-here

# Walrus Memory Relayer URL (public endpoint provided by Walrus Foundation)
MEMWAL_RELAYER_URL=https://relayer.memory.walrus.xyz

# === GOOGLE GEMINI API (Required for AI responses) ===
# Get from https://aistudio.google.com/
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# === SERVER ===
PORT=3000

# === DEMO MODE ===
# Set to "true" to use simulated memory (no Walrus keys needed)
DEMO_MODE=false
